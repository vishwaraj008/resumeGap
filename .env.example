# Root .env for docker-compose. THIS FILE IS OPTIONAL.
#
# `docker compose up -d --build` works with no .env at all — docker-compose.yml
# ships safe defaults for local use. Copy this file to `.env` and edit only if you
# want to override credentials (e.g. for a real deployment). Values set here are
# shared by the mysql container and the backend, so they always stay in sync.

# --- Database ---
DB_NAME=skillgap_db
DB_USER=skillgap_user
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root

# --- Auth ---
# Leave JWT_SECRET_KEY unset for local use: the backend auto-generates a strong
# random key on first boot and persists it. Set it explicitly ONLY if you need a
# fixed key (production, or multiple backend instances sharing one key).
# JWT_SECRET_KEY=generate_a_long_random_secret
JWT_EXPIRY_HOURS=24

# --- URLs ---
FRONTEND_URL=http://localhost:3000
# Baked into the frontend bundle at build time (browser -> backend host port).
VITE_API_URL=http://localhost:8000
